{
  "name": "sigma-wasm",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:wasm && vite build",
    "build:wasm": "./scripts/build.sh",
    "build:docker": "docker build -t sigma-wasm .",
    "preview": "vite preview",
    "start": "vite preview --host --port 3000",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "type-check": "vue-tsc --noEmit",
    "check": "npm run type-check && npm run lint"
  },
  "dependencies": {
    "@babylonjs/core": "^9.12.0",
    "@babylonjs/gui": "^9.12.0",
    "@babylonjs/loaders": "^9.12.0",
    "@babylonjs/materials": "^9.12.0",
    "@babylonjs/serializers": "^9.12.0",
    "@huggingface/tokenizers": "^0.0.6",
    "@mdi/font": "^7.4.47",
    "@xenova/transformers": "^2.17.2",
    "onnxruntime-web": "^1.26.0",
    "recast-navigation": "^0.43.1",
    "vue": "^3.5.38",
    "vuetify": "^4.1.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^8.57.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-tsc": "^3.3.5"
  }
}
