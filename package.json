{
  "name": "sigma-wasm",
  "version": "0.4.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:wasm && vite build",
    "build:wasm": "./scripts/build.sh",
    "build:package": "./scripts/build-package.sh",
    "build:package:pro": "./scripts/build-package-pro.sh",
    "build:docker": "docker build -t sigma-wasm .",
    "preview": "vite preview",
    "start": "vite preview --host --port 3000",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "type-check": "vue-tsc --noEmit && tsc -p tsconfig.react.json --noEmit",
    "check": "npm run type-check && npm run lint",
    "check:handedness": "node examples/handedness-check.mjs"
  },
  "dependencies": {
    "@babylonjs/core": "^9.16.1",
    "@babylonjs/gui": "^9.16.1",
    "@babylonjs/loaders": "^9.16.1",
    "@babylonjs/materials": "^9.16.1",
    "@babylonjs/serializers": "^9.16.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@huggingface/tokenizers": "^0.0.6",
    "@mdi/font": "^7.4.47",
    "@mkkellogg/gaussian-splats-3d": "^0.4.7",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.5.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@splatwalk/core": "0.4.1",
    "@xenova/transformers": "^2.17.2",
    "fflate": "^0.8.3",
    "onnxruntime-web": "^1.26.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recast-navigation": "^0.43.1",
    "three": "^0.169.0",
    "vue": "^3.5.38",
    "vuetify": "^4.1.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^8.57.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-tsc": "^3.3.5"
  }
}
